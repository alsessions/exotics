{% set highlights = craft.entries
    .field('menuItems')
    .featured(true)
    .limit(3)
    .all() %}

{% if highlights | length %}
    <section class="py-16 px-8 max-w-5xl mx-auto">
        <h2 class="text-2xl font-bold mb-8 text-center">Today's Highlights</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for item in highlights %}
                <div class="bg-white rounded-xl shadow-sm p-6 border border-stone-200">
                    <h3 class="font-semibold text-lg mb-1">{{ item.title }}</h3>
                    {% if item.body %}
                        <p class="text-stone-500 text-sm mb-3">{{ item.body }}</p>
                    {% endif %}
                    {% if item.price %}
                        <span class="text-amber-600 font-bold">{{ item.price | money }}</span>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </section>
{% endif %}
