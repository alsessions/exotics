{% extends '_layout' %}

{% block title %}Menu – Exotic Deli and Grill{% endblock %}

{% set categories = craft.entries.section('menu').all() %}

{% block content %}

<div class="bg-neutral-950 text-white min-h-screen py-8 px-4">
  <div class="max-w-7xl mx-auto">

    {# Page heading #}
    <div class="text-center mb-8">
      <h1 class="text-amber-400 text-4xl font-black uppercase tracking-widest leading-none">Exotic Grill</h1>
      <p class="text-white text-sm font-bold uppercase tracking-widest mt-1">NYC Style Deli</p>
      <div class="flex justify-center gap-6 mt-2">
        <span class="text-amber-400 text-xs font-bold uppercase tracking-widest">Coffee</span>
        <span class="text-amber-400 text-xs font-bold uppercase tracking-widest">Breakfast</span>
        <span class="text-amber-400 text-xs font-bold uppercase tracking-widest">Lunch</span>
        <span class="text-amber-400 text-xs font-bold uppercase tracking-widest">Snacks</span>
        <span class="text-amber-400 text-xs font-bold uppercase tracking-widest">Dinner</span>
      </div>
    </div>

    {# Menu sections — CSS columns for natural deli-board flow #}
    <div class="columns-1 sm:columns-2 lg:columns-3 gap-x-6">

      {% for category in categories %}
        <div class="mb-5 break-inside-avoid">

          {# Section header #}
          <div class="border-b-2 border-amber-400 pb-1 mb-2 text-center">
            <h3 class="text-amber-400 font-black uppercase tracking-wider text-base leading-tight">
              {{ category.title }}
            </h3>
          </div>

          {# Menu items #}
          {% set items = category.menuItems.all() %}
          {% if items | length %}
            {% for item in items %}
              <div class="flex justify-between items-start gap-2 py-1 border-b border-neutral-800 last:border-0">
                <div class="flex-1 min-w-0">
                  <p class="text-white font-semibold text-xs leading-snug">{{ item.title }}</p>
                  {% if item.body %}
                    <div class="text-neutral-400 text-xs leading-snug [&_p]:text-xs [&_p]:leading-snug">{{ item.body }}</div>
                  {% endif %}
                </div>
                {% if item.price %}
                  <span class="text-white font-bold text-xs shrink-0 tabular-nums">
                    {{ item.price | money }}
                  </span>
                {% endif %}
              </div>
            {% endfor %}
          {% endif %}

        </div>
      {% endfor %}

    </div>

    {# Contact / Hours footer #}
    <div class="mt-10 border-t border-amber-400 pt-6 text-center">
      <p class="text-amber-400 font-bold text-sm uppercase tracking-widest">📍 264 Suite A Broadway, Whitehall NY, 12887</p>
      <p class="text-white text-sm mt-1">📞 518-499-5600</p>
      <p class="text-neutral-400 text-xs mt-1 uppercase tracking-widest">Business Hours: 6am – 9pm</p>
    </div>

  </div>
</div>

{% endblock %}
