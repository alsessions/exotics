{% extends '_layout' %}

{% block title %}Menu – Exotic Deli and Grill{% endblock %}

{% set categories = craft.entries.section('menu').all() %}

{% block content %}

    <div class="py-16 px-8 max-w-5xl mx-auto">
        <h2 class="text-2xl font-bold mb-12 text-center">Our Menu</h2>

        {% for category in categories %}
            <section class="mb-12">
                <h3 class="text-xl font-bold mb-6 pb-3 border-b border-stone-200">{{ category.title }}</h3>

                {% set items = category.menuItems.all() %}
                {% if items | length %}
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {% for item in items %}
                            <div class="flex justify-between items-start gap-4 py-3 border-b border-stone-100">
                                <div>
                                    <p class="font-semibold">{{ item.title }}</p>
                                    {% if item.body %}
                                        <p class="text-stone-500 text-sm">{{ item.body }}</p>
                                    {% endif %}
                                </div>
                                {% if item.price %}
                                    <span class="text-amber-600 font-bold shrink-0">{{ item.price | money }}</span>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </section>
        {% endfor %}

    </div>

{% endblock %}
